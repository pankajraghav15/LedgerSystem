<%- include("partials/header") %>

<div class="container dashboard-wrapper">
    <header class="dashboard-header">
        <h2>Dashboard</h2>
        <p>Welcome, <strong><%= user.name %></strong> | <span class="badge"><%= user.role %></span></p>
    </header>

    <section class="stats-grid">
        <div class="stat-card income">
            <small>Total Income</small>
            <h3>₹<%= summary.totalIncome %></h3>
        </div>
        <div class="stat-card expense">
            <small>Total Expenses</small>
            <h3>₹<%= summary.totalExpense %></h3>
        </div>
        <div class="stat-card balance">
            <small>Net Balance</small>
            <h3>₹<%= summary.netBalance %></h3>
        </div>
    </section>

    <div class="main-content">
        <section class="form-section">
            <h3>Add Record</h3>
            <form action="/records/add" method="POST" class="inline-form">
                <input type="number" name="amount" placeholder="Amount" required>
                <select name="type">
                    <option value="expense">Expense</option>
                    <option value="income">Income</option>
                </select>
                <input type="text" name="category" placeholder="Category" required>
                <input type="date" name="date" required>
                <button type="submit" class="btn-success">Add</button>
            </form>
        </section>

        <section class="table-section">
            <h3>Recent Activity</h3>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (records.length > 0) { %>
                            <% records.forEach(rec => { %>
                                <tr>
                                    <td><%= new Date(rec.date).toLocaleDateString() %></td>
                                    <td><%= rec.category %></td>
                                    <td class="type-<%= rec.type %>"><%= rec.type.toUpperCase() %></td>
                                    <td>₹<%= rec.amount %></td>
                                    <td>
                                        <a href="/records/delete/<%= rec._id %>" class="text-danger" onclick="return confirm('Delete?')">Delete</a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center">No records found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <hr>

    <footer class="dashboard-settings">
        <div class="settings-grid">
            <div class="settings-box">
                <h4>Update Profile</h4>
                <form action="/update-profile" method="POST">
                    <input type="text" name="name" value="<%= user.name %>" required>
                    <input type="email" name="email" value="<%= user.email %>" required>
                    <button type="submit">Update Info</button>
                </form>
            </div>
            <div class="settings-box">
                <h4>Change Password</h4>
                <form action="/update-password" method="POST">
                    <input type="password" name="currentPassword" placeholder="Current Password" required>
                    <input type="password" name="newPassword" placeholder="New Password" required>
                    <button type="submit">Change Password</button>
                </form>
            </div>
        </div>
        <div class="logout-area">
            <a href="/logout" class="btn-logout">Logout System</a>
        </div>
    </footer>
</div>

<%- include("partials/footer") %>